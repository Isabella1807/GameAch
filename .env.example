# Copy this file to ".env" and fill in your values.
#
# These are read ONLY by the Steam sync script (server-side / GitHub Action),
# NEVER by the Vite frontend — so do NOT add a VITE_ prefix to them.
# In production the values live in GitHub Actions secrets, not in this file.

# Steam Web API key — https://steamcommunity.com/dev/apikey  (KEEP SECRET)
STEAM_API_KEY=

# Your SteamID64 — the 17-digit number (find it via your profile URL or steamid.io)
STEAM_ID=

# Coral Island Steam app id (no need to change)
STEAM_APP_ID=1158160

# Icarus Steam app id (no need to change)
STEAM_ICARUS_APP_ID=1149460
